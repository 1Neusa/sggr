// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}


  model Gravidas{
  id Int @id @default(autoincrement())
  nome String
  nascimento DateTime
  endereco String?
  estado_civil String?
  num_tel String
  num_proximo String?                                             
  ultima_mestr DateTime
  num_gravidez Int?
  tipos_partos String
  data_provavel_parto DateTime
  doencas_ant String
  doencas_pre String
  data_cadastro DateTime
  func_Id Int
  func Funcionarios @relation(fields: [func_Id], references: [id])  
  doctor_Id Int
  doctor Doctor @relation(fields: [doctor_Id], references: [id])

  medicamentos Medicamento[]
}

model Funcionarios{
  id Int @id @default(autoincrement())
  nome String
  ender String
  tel String
  cargo String
  profissao String?
  tipo_func String
  cod_acesso String
  gravidas Gravidas[]
}

model Doctor{
  id Int @id @default(autoincrement())
  nome String
  ender String
  especialidade String?
  cod_acesso String
  gravidas Gravidas[]
}






model Medicamento {
  id  Int      @id @default(autoincrement())
  nome             String
  descricao        String
  dosagem          String
  data_inicio      DateTime
  data_fim         DateTime?
  id_Gravidas    Int

  gravida      Gravidas @relation(fields: [id_Gravidas], references: [id])
}